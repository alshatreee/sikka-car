# Copy to .env and fill in your values

# Polygon wallet
POLYGON_PRIVATE_KEY=your_private_key_without_0x
POLYGON_ADDRESS=0xYOUR_WALLET_ADDRESS

# Capital
CAPITAL_USD=1000

# Trading mode: manual | semi_auto | full_auto
TRADING_MODE=manual

# Database — Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# App URL
NEXT_PUBLIC_APP_URL=https://sikkacar.com

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Cloudinary — Image uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Tap Payments — Payment gateway
TAP_SECRET_KEY=sk_test_...

# ===== Kazima AI =====
# Choose ONE provider: Anthropic OR OpenAI (Anthropic takes priority if both set)

# Option A: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI or OpenAI-compatible (local models, etc.)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Override the default model ID
# KAZIMA_MODEL_ID=claude-sonnet-4-20250514

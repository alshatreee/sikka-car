// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CarStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  AWAITING_PAYMENT
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
  ELECTRIC
}

model User {
  id             String    @id @default(cuid())
  clerkUserId    String    @unique
  email          String    @unique
  fullName       String?
  phone          String?
  civilId                  String?
  civilIdImageFront        String?
  civilIdImageBack         String?
  drivingLicense           String?
  drivingLicenseImageFront String?
  drivingLicenseImageBack  String?
  role                UserRole  @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  cars              Car[]
  bookings          Booking[]         @relation("RenterBookings")
  sentMessages      Message[]         @relation("SentMessages")
  receivedMessages  Message[]         @relation("ReceivedMessages")
}

model Car {
  id               String           @id @default(cuid())
  ownerId          String
  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title            String
  titleEn          String?
  brand            String?
  model            String?
  year             Int
  dailyPrice       Decimal          @db.Decimal(10, 2)

  area             String
  city             String?
  origin           String?
  type             String?
  category         String?

  seats            Int?
  transmission     TransmissionType?
  smokingPolicy    String?
  distancePolicy   String?
  minAge           Int?
  availabilityText String?
  notes            String?

  images           String[]
  documentImages   String[]

  status           CarStatus        @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  bookings         Booking[]

  @@index([ownerId])
  @@index([status])
}

model Booking {
  id               String        @id @default(cuid())
  carId            String
  renterId         String

  car              Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  renter           User          @relation("RenterBookings", fields: [renterId], references: [id], onDelete: Cascade)

  startDate        DateTime
  endDate          DateTime
  pickupTime       String?
  dropoffTime      String?
  totalDays        Int
  totalAmount      Decimal       @db.Decimal(10, 2)
  notes            String?

  civilId               String?
  licenseNumber         String?
  civilIdImageFront     String?
  civilIdImageBack      String?
  licenseImageFront     String?
  licenseImageBack      String?

  paymentReference String?
  paymentUrl       String?
  status           BookingStatus @default(PENDING)

  cancellationReason String?
  cancelledAt        DateTime?
  refundPercentage   Int?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  review           Review?
  photos           BookingPhoto[]
  messages         Message[]
  inspections      CarInspection[]

  @@index([carId])
  @@index([renterId])
  @@index([status])
  @@index([startDate, endDate])
}

model BookingPhoto {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  url         String
  type        String
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  bookingId  String?
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  booking    Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([receiverId, read])
  @@index([senderId])
  @@index([bookingId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model CarInspection {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type      String   // "PICKUP" or "RETURN"
  photos    String[] // Array of Cloudinary URLs
  notes     String?
  mileage   Int?
  fuelLevel String?  // "FULL", "3/4", "1/2", "1/4", "EMPTY"
  createdBy String   // userId who submitted
  createdAt DateTime @default(now())
}

// ===== Kazima AI - Scholarly Research System =====

model KazimaAnalysis {
  id               String   @id @default(cuid())
  userId           String?
  mode             String   // analysis, extraction, annotation, publication, media, etc.
  inputText        String   @db.Text
  result           String   @db.Text
  additionalContext String? @db.Text
  title            String?
  isFavorite       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([mode])
  @@index([createdAt])
}

model KazimaManuscript {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  author      String?
  period      String?
  tradition   String?
  rawText     String   @db.Text
  notes       String?  @db.Text
  imageUrls   String[]
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model KazimaDocument {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  content     String   @db.Text
  source      String?  // Book name, manuscript reference, etc.
  author      String?
  period      String?
  region      String?
  category    String?  // تاريخ سياسي، تاريخ ديني، تراجم، etc.
  tags        String[]
  metadata    String?  @db.Text // JSON string for extra structured data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

model KazimaGraphData {
  id            String   @id @default(cuid())
  userId        String?
  analysisId    String?
  nodesJson     String   @db.Text // JSON array of nodes
  edgesJson     String   @db.Text // JSON array of edges
  sourceText    String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([analysisId])
}
